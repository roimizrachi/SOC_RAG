{
  "mapping_name": "event_metadata_mapping_v1",
  "description": "Field mapping for extracting Event-level Metadata Index from a QRadar event with Cisco Secure Endpoint utf8_payload.",
  "source_file_example": "offense_82303_events_964_fixed(1).json",
  "notes": [
    "Each QRadar event contains an outer event object and an inner utf8_payload JSON string.",
    "Extractor should parse event['utf8_payload'] with json.loads before applying utf8_payload paths.",
    "Fields are intended for exact match and filtering at the Event Metadata Index layer.",
    "Arrays use [] to indicate values should be collected from all objects in the array.",
    "Missing fields should return null or an empty list, depending on field cardinality."
  ],
  "event_identity": {
    "offense_id": {
      "source": "provided_by_pipeline",
      "type": "string",
      "cardinality": "single",
      "required": true,
      "description": "Offense identifier supplied by filename, QRadar API, or pipeline context."
    },
    "event_index": {
      "source": "generated_by_pipeline",
      "type": "integer",
      "cardinality": "single",
      "required": true,
      "description": "Zero-based index of the event inside the offense events array."
    },
    "event_id": {
      "source": "utf8_payload.id",
      "type": "string",
      "cardinality": "single",
      "required": true,
      "description": "Cisco Secure Endpoint event id."
    }
  },
